# Виртуальное окружение (самое важное!)
.venv/
venv/
env/
ENV/

# Файлы Python (компилированные байт-коды)
__pycache__/
*.py[cod]
*.so

# Файлы IDE (если хотите игнорировать настройки VS Code)
.vscode/
.idea/

# Логи и базы данных
*.log
*.sqlite3
*.db

# Файлы с секретами (никогда не публикуйте!)
.env
.secrets